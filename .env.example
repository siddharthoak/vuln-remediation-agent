# Copy to .env and fill in every value before running.
# .env is gitignored — never commit it.

# ── GitHub ────────────────────────────────────────────────────────────────────
GITHUB_REPO_TARGET=org/repo-name        # owner/repo of the repo to remediate
GITHUB_PAT=ghp_xxxxxxxxxxxxxxxxxxxx     # PAT with repo + pull_request scopes

# ── Vertex AI (Gemini) ────────────────────────────────────────────────────────
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
VERTEX_LOCATION=us-central1
VERTEX_MODEL=gemini-2.0-flash-001

# Path to your GCP Application Default Credentials JSON file (local machine path).
# The docker-compose.yml mounts this into the container at /gcp/adc.json.
# Obtain with: gcloud auth application-default login
GOOGLE_APPLICATION_CREDENTIALS=/Users/you/.config/gcloud/application_default_credentials.json

# ── Agent settings ────────────────────────────────────────────────────────────
MAX_RETRY_ATTEMPTS=3
MAX_PARALLEL_FIXES=5
CI_POLL_INTERVAL=30
CI_TIMEOUT_SECONDS=1800
