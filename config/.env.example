# ============================================================
# AI SDLC Agents — Runtime Configuration Template
# Copy to config/.env and fill in values for your environment.
# NEVER commit config/.env to source control.
# ============================================================

# ── Core ─────────────────────────────────────────────────────
CLOUD_PROVIDER=local
AGENT_STORAGE_BUCKET=aisdlcconsolidated

# ── Google Vertex AI (required) ───────────────────────────────
# Path inside the container where the GCP SA key is mounted.
# The docker-compose mounts secrets/gcp-sa.json here — do not change this.
GOOGLE_APPLICATION_CREDENTIALS=/run/secrets/gcp-sa.json

# Your GCP project ID and region
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
PROJECT_ID=your-gcp-project-id
LOCATION=us-central1

# ── Azure DevOps integration (optional) ───────────────────────
# Only required if you want generated work items pushed to Azure DevOps.
# In local mode, work items are stored locally regardless of these settings.
AZURE_DEVOPS_PAT=
AZURE_DEVOPS_ORG=

# ── AWS (CLOUD_PROVIDER=aws only — leave blank for local) ────
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
# AWS_DEFAULT_REGION=us-east-1

# ── Migration agent config (optional — not needed for work item authoring) ──
# BRD_SPEC_S3_PATH=s3://your-bucket/brd-prompt.md
# OUTPUT_BUCKET=your-bucket
# OUTPUT_KEY=brd_output/Analysis_BRD.html
# MIGRATION_SPEC_PATH=s3://your-bucket/migration-prompt.md
